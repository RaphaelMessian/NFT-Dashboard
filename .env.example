# Hedera Testnet Account
# Get your testnet account at https://portal.hedera.com/
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=0x...your_ecdsa_private_key_here

# After deploying the contract, fill this in
NFT_CONTRACT_ADDRESS=0x...deployed_contract_address

# ── Dashboard Config ──
# NFT contracts to monitor (comma-separated)
# Accepts Hedera contract IDs (0.0.XXXXX) or EVM addresses (0x...)
# Format: label:id,label:id,...
VITE_NFT_CONTRACTS=Launch NFT:0.0.XXXXX
# Creator account ID for wallet tracking
VITE_ACCOUNT_ID=0.0.XXXXX
# How often the sync container re-fetches on-chain data (minutes). Set to 0 for one-shot.
SYNC_INTERVAL_MINUTES=1